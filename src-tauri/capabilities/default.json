{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window + the voice call pill",
  "windows": ["main", "call"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "opener:default",
    "dialog:default",
    "notification:default"
  ]
}
